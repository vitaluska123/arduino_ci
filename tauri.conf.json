{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arduino CI",
  "version": "0.2.1",
  "identifier": "com.arduino.ci",
  "build": {
    "frontendDist": "frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Arduino CI",
        "width": 520,
        "height": 640,
        "decorations": false,
        "shadow": false,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  }
}
